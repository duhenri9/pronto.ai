# ── Banco de Dados (Neon, PostgreSQL 16, região sa-east-1) ──
DATABASE_URL=postgresql://<user>:<pass>@ep-<id>.sa-east-1.aws.neon.tech/pronto_ia?sslmode=require&channel_binding=require

# ── Redis (Upstash, região sa-east-1) ──
REDIS_URL=redis://default:<password>@<host>:6379

# ── Anthropic (Haiku 4.5 + Sonnet 4.5, sem intermediários) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp (Z-API, provider primário para MVP) ──
WHATSAPP_PROVIDER=zapi
ZAPI_INSTANCE_ID=instance_...
ZAPI_TOKEN=token_...
ZAPI_SECURITY_TOKEN=security_token_...
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<uuid-aleatorio>

# ── Pagamento (AbacatePay, Pix mensal R$29) ──
ABACATE_PAY_API_KEY=
NEXT_PUBLIC_BASE_URL=https://pronto-ia.vercel.app

# ── Meta Cloud API (fallback futuro, opcional) ──
WHATSAPP_APP_SECRET=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# ── Segurança ──
JWT_SECRET=<jwt-secret-aqui>
COOKIE_SECRET=<cookie-secret-aqui>
ADMIN_SECRET=<admin-secret-aqui>

# ── Sentry (Observabilidade) ──
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org-id>.ingest.<region>.sentry.io/<project-id>
SENTRY_DSN=https://<key>@o<org-id>.ingest.<region>.sentry.io/<project-id>
SENTRY_AUTH_TOKEN=sntrys_...

# ── Resend (Email Transacional) ──
RESEND_API_KEY=re_...

# ── Rate Limit (webhook allowlist, separado por vírgula) ──
RATE_LIMIT_ALLOWLIST=5511XXXXXXXXX,5511YYYYYYYYY

# ── Google AI (Gemini Flash, router de intents — Issue #6) ──
GOOGLE_AI_API_KEY=

# ── LLM Feature Flags (kill switch + fallback — Issue #7) ──
LLM_PROVIDER_PRIMARY=anthropic
LLM_PROVIDER_FALLBACK=openai
LLM_FALLBACK_ENABLED=false

# ── Observabilidade (Sentry, plano grátis) ──
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Câmbio para cálculo de custo LLM (centavos de BRL por USD) ──
USD_TO_BRL_CENTS=550