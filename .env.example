# ============================================
# PRONTO.IA — Environment Configuration
# ============================================

# General
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL="postgresql://pronto:pronto@localhost:5432/pronto_ia?schema=public"

# Auth
JWT_SECRET=pronto-ia-dev-secret-change-in-production
COOKIE_SECRET=pronto-ia-dev-cookie-secret-change-in-prod

# API
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Web
VITE_API_URL=http://localhost:3001/api/v1

# WhatsApp — Cloud API (production) or Z-API (pilot)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_PROVIDER=zapi   # "zapi" for pilot (<1k students), "cloud_api" for scale

# Z-API (pilot)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=

# AI / LLM — OpenRouter
OPENROUTER_API_KEY=
AI_DEFAULT_MODEL=z-ai/glm-4.7-flash
AI_DEFAULT_MAX_TOKENS=800
AI_COST_PER_1K_INPUT_CENTS=0.06
AI_COST_PER_1K_OUTPUT_CENTS=0.40

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADO_PAGO_ACCESS_TOKEN=

# B2C Pro pricing
PRO_MONTHLY_PRICE_CENTS=1900
